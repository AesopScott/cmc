---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Community Medical Centers — Quality healthcare for all.' } = Astro.props;
const path = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Community Medical Centers</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Skip link (WCAG 2.4.1) -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- Utility Bar -->
  <div class="utility-bar">
    <div class="utility-bar-inner">
      <a href="tel:2099444700">(209) 944-4700</a>
      <span class="util-divider" aria-hidden="true">|</span>
      <a href="https://mychart.ochin.org/cmcenters/Authentication/Login?" target="_blank" rel="noopener noreferrer">Patient Portal</a>
      <span class="util-divider" aria-hidden="true">|</span>
      <a href="https://communitymedicalcenters.networkforgood.com/projects/198038-communitymedical-center-inc-general-giving" target="_blank" rel="noopener noreferrer">Donate</a>
    </div>
  </div>

  <!-- Main Nav -->
  <nav class="site-nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Community Medical Centers home">
        <img src="/img/cmc-logo.svg" alt="Community Medical Centers" />
      </a>
      <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-links">
        <span aria-hidden="true"></span><span aria-hidden="true"></span><span aria-hidden="true"></span>
      </button>
      <ul class="nav-links" id="nav-links">
        <li><a href="/services" class={path.startsWith('/services') ? 'active' : ''}>Services</a></li>
        <li><a href="/locations" class={path.startsWith('/locations') ? 'active' : ''}>Locations</a></li>
        <li><a href="/providers" class={path.startsWith('/providers') ? 'active' : ''}>Providers</a></li>
        <li><a href="/patients" class={path.startsWith('/patients') ? 'active' : ''}>Patients</a></li>
        <li><a href="/about" class={path === '/about/' || path === '/about' ? 'active' : ''}>About</a></li>
        <li><a href="/news" class={path.startsWith('/news') ? 'active' : ''}>News</a></li>
      </ul>
      <a href="tel:2099444700" class="nav-cta">(209) 944-4700</a>
    </div>
  </nav>

  <main id="main-content" tabindex="-1">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col footer-brand">
          <a href="/" aria-label="Community Medical Centers home">
            <img src="/img/cmc-logo.svg" alt="Community Medical Centers" style="height:48px;width:auto" />
          </a>
          <p>Providing quality, compassionate healthcare to all patients regardless of their ability to pay since 1968.</p>
        </div>
        <div class="footer-col">
          <h4>Services</h4>
          <ul>
            <li><a href="/services/adult-medicine">Adult Medicine</a></li>
            <li><a href="/services/pediatrics">Pediatrics</a></li>
            <li><a href="/services/behavioral-health">Behavioral Health</a></li>
            <li><a href="/services/general-dentistry">Dental</a></li>
            <li><a href="/services">All Services →</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Quick Links</h4>
          <ul>
            <li><a href="/locations">Find a Location</a></li>
            <li><a href="/providers">Find a Provider</a></li>
            <li><a href="/patients">Patient Resources</a></li>
            <li><a href="/about">About CMC</a></li>
            <li><a href="/news">News &amp; Events</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Contact</h4>
          <ul>
            <li><a href="tel:2099444700">(209) 944-4700</a></li>
            <li><a href="https://mychart.ochin.org/cmcenters/Authentication/Login?" target="_blank" rel="noopener noreferrer">Patient Portal</a></li>
            <li><a href="https://communitymedicalcenters.networkforgood.com/projects/198038-communitymedical-center-inc-general-giving" target="_blank" rel="noopener noreferrer">Donate</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Community Medical Centers. All rights reserved.</p>
        <p>Federally Qualified Health Center (FQHC)</p>
      </div>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('nav-toggle');
    const links = document.getElementById('nav-links');
    toggle?.addEventListener('click', () => {
      const isOpen = links?.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(!!isOpen));
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && links?.classList.contains('open')) {
        links.classList.remove('open');
        toggle?.setAttribute('aria-expanded', 'false');
        toggle?.focus();
      }
    });
  </script>
</body>
</html>
