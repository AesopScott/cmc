---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Community Medical Centers — Quality healthcare for all.' } = Astro.props;
const path = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Community Medical Centers</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <slot name="head" />
</head>
<body>

  <!-- Skip link (WCAG 2.4.1) -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- Sticky site header: utility bar + main nav -->
  <header class="site-header">

  <!-- Utility Bar -->
  <div class="utility-bar">
    <div class="utility-bar-inner">
      <span class="util-appt">
        Call or Text for Appointments&nbsp;&nbsp;·&nbsp;&nbsp;<a href="tel:2096365400">Medical: (209) 636-5400</a>&nbsp;&nbsp;·&nbsp;&nbsp;<a href="tel:2096365555">Dental: (209) 636-5555</a>
      </span>
      <div class="util-links">
        <a href="/news">News</a>
        <span class="util-divider" aria-hidden="true">|</span>
        <a href="/about">About</a>
        <span class="util-divider" aria-hidden="true">|</span>
        <a href="/careers">Careers</a>
        <span class="util-divider" aria-hidden="true">|</span>
        <a href="https://communitymedicalcenters.networkforgood.com/projects/198038-communitymedical-center-inc-general-giving" target="_blank" rel="noopener noreferrer">Donate</a>
        <span class="util-divider" aria-hidden="true">|</span>
        <a href="https://mychart.ochin.org/cmcenters/Authentication/Login?" target="_blank" rel="noopener noreferrer">Patient Portal</a>
      </div>
    </div>
  </div>

  <!-- Main Nav -->
  <nav class="site-nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Community Medical Centers home">
        <img src="/img/cmc-logo.svg" alt="Community Medical Centers" />
      </a>
      <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-links">
        <span aria-hidden="true"></span><span aria-hidden="true"></span><span aria-hidden="true"></span>
      </button>
      <ul class="nav-links" id="nav-links">
        <li><a href="/locations" class={path.startsWith('/locations') ? 'active' : ''}>Locations</a></li>
        <li><a href="/services" class={path.startsWith('/services') ? 'active' : ''}>Services</a></li>
        <li><a href="/patients" class={path.startsWith('/patients') ? 'active' : ''}>Patients</a></li>
        <li><a href="/providers" class={path.startsWith('/providers') ? 'active' : ''}>Providers</a></li>
        <li><a href="/support-cmc/" class={path === '/support-cmc/' || path === '/support-cmc' ? 'active' : ''}>Support CMC</a></li>
      </ul>
    </div>
  </nav>

  </header><!-- /.site-header -->

  <main id="main-content" tabindex="-1">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">

      <div class="footer-grid">

        <!-- For Stockton Residents -->
        <div class="footer-col">
          <h4>For Stockton Residents</h4>
          <p class="footer-mcr-text"><strong>Mobile Community Response:</strong> In partnership with the City of Stockton, Community Medical Centers offers an alternative to 911 for Stockton citizens in need of behavioral health services. If you or someone you know is experiencing mental distress, please call <a href="tel:8333112273" style="color:rgba(255,255,255,0.85);font-weight:600">(833) 311-2273</a>, 7 days a week, 8:00 am to 11:00 pm. This helpline is for non-violent individuals with mild to moderate symptoms.</p>
        </div>

        <!-- Quick Links -->
        <div class="footer-col">
          <h4>Quick Links</h4>
          <ul class="footer-links-list">
            <li><a href="/locations">Locations</a></li>
            <li><a href="/services">Services</a></li>
            <li><a href="/patients">Patients</a></li>
            <li><a href="/providers">Providers</a></li>
            <li><a href="/support-cmc/">Support CMC</a></li>
            <li><a href="/news">News</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/careers">Careers</a></li>
            <li><a href="/contact">Contact Us</a></li>
            <li><a href="https://communitymedicalcenters.networkforgood.com/projects/198038-communitymedical-center-inc-general-giving" target="_blank" rel="noopener noreferrer">Donate</a></li>
            <li><a href="https://mychart.ochin.org/cmcenters/Authentication/Login?" target="_blank" rel="noopener noreferrer">Patient Portal</a></li>
          </ul>
        </div>

        <!-- Follow Us + E-news -->
        <div class="footer-col">
          <h4>Follow Us</h4>
          <ul class="footer-links-list">
            <li><a href="https://www.facebook.com/cmcenters" target="_blank" rel="noopener noreferrer">Facebook</a></li>
            <li><a href="https://www.instagram.com/cmcenters.inc/" target="_blank" rel="noopener noreferrer">Instagram</a></li>
            <li><a href="https://www.youtube.com/@cmcenters" target="_blank" rel="noopener noreferrer">YouTube</a></li>
            <li><a href="http://x.com/CMCinc78" target="_blank" rel="noopener noreferrer">X (Twitter)</a></li>
          </ul>
          <div class="footer-enews">
            <h4>Get News Updates</h4>
            <div class="ctct-inline-form" data-form-id="b800fa3de98e748a6aa00c9a4b40812a"></div>
          </div>
        </div>

      </div>

      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Community Medical Centers. All rights reserved. &nbsp;·&nbsp; Federally Qualified Health Center (FQHC)</p>
        <nav aria-label="Legal links" class="footer-legal">
          <a href="https://cmcenters.org/terms-of-use/">Terms of Use</a>
          <span class="util-divider" aria-hidden="true">|</span>
          <a href="https://cmcenters.org/privacy-policy/">Privacy Policy</a>
          <span class="util-divider" aria-hidden="true">|</span>
          <a href="https://cmcenters.org/non-discrimination-notice/">Non-Discrimination Notice</a>
          <span class="util-divider" aria-hidden="true">|</span>
          <a href="https://cmcenters.org/fqhc-notifications/">FQHC Notifications</a>
        </nav>
      </div>

    </div>
  </footer>

  <script>
    const toggle = document.getElementById('nav-toggle');
    const links = document.getElementById('nav-links');
    toggle?.addEventListener('click', () => {
      const isOpen = links?.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(!!isOpen));
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && links?.classList.contains('open')) {
        links.classList.remove('open');
        toggle?.setAttribute('aria-expanded', 'false');
        toggle?.focus();
      }
    });
  </script>

  <!-- Constant Contact Active Forms -->
  <script>var _ctct_m = "b800fa3de98e748a6aa00c9a4b40812a";</script>
  <script id="signupScript" src="//static.ctctcdn.com/js/signup-form-widget/current/signup-form-widget.min.js" async defer></script>

</body>
</html>
