[
    {
        "id": 367,
        "slug": "adult-medicine",
        "title": "Adult Medicine",
        "url": "https://cmcenters.org/health-services/adult-medicine/",
        "date": "2023-07-18 03:23:42",
        "modified": "2025-05-07 09:25:41",
        "excerpt": "",
        "content": "<ul>\r\n \t<li>Immunizations and health screenings</li>\r\n \t<li>Treatment of acute and chronic conditions</li>\r\n \t<li>Family planning and birth control</li>\r\n \t<li>STD testing, treatment, and protection</li>\r\n \t<li>Sick visits</li>\r\n</ul>\r\nYour primary care provider leads a team-based approach that includes physicians, nurses, social workers, and health educators.\r\n\r\nYour health team is committed to providing you the care you need in the language you speak, with the information you need to make important decisions about your health.\r\n\r\nFrom regular screenings and sick visits to vaccinations and family planning, our approach puts you at the center of your care, giving you everything you need to live your healthiest life.",
        "thumbnail": "/img/2023__11__CMC-Services-Adult-Medicine.jpg",
