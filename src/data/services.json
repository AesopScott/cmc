    {
        "id": 374,
        "slug": "enrollment-assistance",
        "title": "Health Coverage Counseling",
        "url": "https://cmcenters.org/health-services/enrollment-assistance/",
        "date": "2023-07-18 04:16:30",
        "modified": "2024-12-10 20:15:15",
        "excerpt": "",
        "content": "If you don’t have insurance, or you have questions about your coverage options, the CMC team is here to help. Call or text us at <a href=\"tel:+2093732824\">(209) 373-2824</a> for more information.\r\n\r\nOur Certified Enrollment Counselors (CECs) will work with you and your family to help you enroll in the health plan that best fits your needs.\r\n\r\nOur team can also help you find community-based resources, including housing, transportation, food, and more.\r\n\r\nIf you have questions, or would like to set up an appointment, call or text us at <a href=\"tel:+2093732824\">(209) 373-2824</a>.",
        "thumbnail": "/img/2023__11__CMC-Services-Enrollment-Assistance.jpg",
