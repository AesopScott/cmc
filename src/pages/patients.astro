---
import Base from '../layouts/Base.astro';
---
<Base title="Patients" description="Patient information for Community Medical Centers — insurance, forms, health records, rights, and payment assistance.">

  <!-- Hero -->
  <section class="hero" style="padding:5rem 0 4rem">
    <div class="container">
      <span class="hero-eyebrow">Patient Resources</span>
      <h1>Healthcare that puts <em>patients first</em></h1>
      <p>Healthcare starts with you at CMC. You get a skilled team of caring professionals committed to improving your whole health.</p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:2rem">
        <a href="tel:2096365400" class="btn-primary">Medical: (209) 636-5400</a>
        <a href="tel:2096365555" class="btn-outline">Dental: (209) 636-5555</a>
      </div>
    </div>
  </section>

  <!-- Insurance & Coverage -->
  <section class="section">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start" class="responsive-2col">
        <div>
          <span class="eyebrow">Coverage</span>
          <h2 style="margin-top:0.5rem">Health Coverage Assistance</h2>
          <p style="color:var(--muted)">CMC serves all patients regardless of their ability to pay. Our staff can help you enroll in coverage — no appointment needed.</p>
          <p style="color:var(--muted)">Please bring your insurance ID card and any required copayments to your appointment.</p>
          <p style="margin-top:1.5rem">
            <strong style="color:var(--cream)">Need enrollment help?</strong><br />
            <a href="tel:2093732824" style="color:var(--gold)">(209) 373-2824</a> — Certified Enrollment Counselors available
          </p>
        </div>
        <div>
          <div style="background:var(--navy-mid);border:1px solid var(--border);border-radius:8px;padding:2rem">
            <h3 style="font-size:1rem;margin-bottom:1.25rem;color:var(--gold)">Insurance Accepted</h3>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.6rem">
              {[
                'Medi-Cal',
                'Medi-Cal Managed Care (Health Plan of San Joaquin, Health Net, Partnership Health Plan of California)',
                'Medicare',
                'Medicare Advantage Plans',
                'Covered California',
              ].map(ins => (
                <li style="display:flex;align-items:flex-start;gap:0.6rem;color:var(--muted);font-size:0.9rem">
                  <span style="color:var(--gold);flex-shrink:0;margin-top:0.1rem">✓</span>
                  {ins}
                </li>
              ))}
            </ul>
            <div style="margin-top:1.5rem;padding-top:1.25rem;border-top:1px solid var(--border)">
              <p style="font-size:0.875rem;color:var(--muted);margin:0">
                <strong style="color:var(--cream)">Uninsured?</strong> Depending on your family size, income, and housing, you may qualify for free or low-cost care.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Patient Portal -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Health Records</span>
        <h2>Patient Portal</h2>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start" class="responsive-2col">
        <div>
          <p style="color:var(--muted)">Access your health information anytime through our secure online portal.</p>
          <ul style="list-style:none;padding:0;margin:1.25rem 0;display:flex;flex-direction:column;gap:0.75rem">
            {[
              'Send and receive messages with your primary care provider',
              'Access your health records',
              'Request appointments',
              'View latest test results',
              'View, download, and share your personal health records',
              'Search health and wellness information',
            ].map(feature => (
              <li style="display:flex;align-items:flex-start;gap:0.6rem;color:var(--muted);font-size:0.9rem">
                <span style="color:var(--gold);flex-shrink:0;margin-top:0.1rem">✓</span>
                {feature}
              </li>
            ))}
          </ul>
          <a href="https://mychart.ochin.org/cmcenters/Authentication/Login?" target="_blank" rel="noopener noreferrer" class="btn-primary" style="display:inline-block;margin-top:0.5rem">Access Patient Portal</a>
        </div>
        <div style="background:var(--navy-mid);border:1px solid var(--border);border-radius:8px;padding:2rem">
          <h3 style="font-size:1rem;margin-bottom:1rem;color:var(--gold)">Setting Up Your Account</h3>
          <ol style="padding-left:1.25rem;margin:0;display:flex;flex-direction:column;gap:0.75rem;color:var(--muted);font-size:0.9rem">
            <li>Download the free <strong style="color:var(--cream)">NextGen Patient Portal</strong> app</li>
            <li>Visit <a href="https://nextmd.com" target="_blank" rel="noopener noreferrer" style="color:var(--gold)">nextmd.com</a> to create your account</li>
            <li>Need your enrollment code? Call <a href="tel:2094306222" style="color:var(--gold)">(209) 430-6222</a>, Mon–Fri 8am–5pm</li>
          </ol>
          <div style="margin-top:1.5rem;padding-top:1.25rem;border-top:1px solid var(--border)">
            <h3 style="font-size:1rem;margin-bottom:0.75rem;color:var(--gold)">Medical Records Requests</h3>
            <p style="font-size:0.875rem;color:var(--muted);margin:0 0 0.75rem">Submit a completed form by:</p>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.4rem;font-size:0.875rem;color:var(--muted)">
              <li>Fax: <a href="fax:2097626808" style="color:var(--gold)">(209) 762-6808</a></li>
              <li>Email: <a href="mailto:prforms@cmcenters.org" style="color:var(--gold)">prforms@cmcenters.org</a></li>
              <li>Mail: P.O. Box 779, Stockton CA 95201</li>
            </ul>
            <p style="font-size:0.875rem;color:var(--muted);margin:0.75rem 0 0">Health Information Dept: <a href="tel:2095463870" style="color:var(--gold)">(209) 546-3870</a></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Patient Forms -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Forms</span>
        <h2>Patient Forms</h2>
      </div>
      <p style="color:var(--muted);max-width:600px;margin:0 auto 2.5rem;text-align:center">All forms are available in English and Spanish. Download, complete, and bring to your appointment or submit as instructed.</p>
      <div class="grid-3" style="gap:1.25rem">
        {[
          {
            title: 'Patient Registration',
            eng: 'https://cmcenters.org/wp-content/uploads/2026/03/ENG_Patient-Registration_FINAL-05-09-25.pdf',
            spa: 'https://cmcenters.org/wp-content/uploads/2025/05/SPA_Patient-Registration_FINAL-05-09-25.pdf',
          },
          {
            title: 'Advance Directive',
            eng: 'https://cmcenters.org/wp-content/uploads/2026/03/ENG_Advance-Directive-Acknowledgement_Rev-3-2024.pdf',
            spa: 'https://cmcenters.org/wp-content/uploads/2025/03/SPA_Advance-Directive-Acknowledgement_Rev-11-2025.pdf',
          },
          {
            title: 'Medicare Annual Wellness Visit Health Risk Assessment',
            eng: 'https://cmcenters.org/wp-content/uploads/2026/03/Medicare-AWV-Health-Risk-Assessment-_ENGLISH.pdf',
            spa: 'https://cmcenters.org/wp-content/uploads/2026/03/Medicare-AWV-Health-Risk-Assessment_SPANISH.pdf',
          },
          {
            title: 'Medical Records Request',
            eng: 'https://cmcenters.org/wp-content/uploads/2026/03/ENG_Medical-Records-Request_FINAL-05-2025.pdf',
            spa: 'https://cmcenters.org/wp-content/uploads/2025/08/SPA_Medical-Records-Request_FINAL-05-2025.pdf',
          },
          {
            title: 'Sliding Fee Discount Application',
            eng: 'https://cmcenters.org/wp-content/uploads/2026/03/ENG_Sliding-Fee-Discount-Application_FINAL-07-2025.pdf',
            spa: 'https://cmcenters.org/wp-content/uploads/2025/08/SPA_Sliding-Fee-Discount-Application_FINAL-07-2025.pdf',
          },
          {
            title: 'Patient Complaint Form',
            jotform: 'https://form.jotform.com/240815529548060',
          },
        ].map(form => (
          <div style="background:var(--navy-mid);border:1px solid var(--border);border-radius:8px;padding:1.5rem;display:flex;flex-direction:column">
            <h3 style="font-size:0.95rem;margin:0 0 1rem;color:var(--cream);flex:1">{form.title}</h3>
            <div style="display:flex;gap:0.75rem;flex-wrap:wrap">
              {form.jotform ? (
                <a href={form.jotform} target="_blank" rel="noopener noreferrer" class="badge" style="text-decoration:none;padding:0.4rem 0.75rem">Open Form</a>
              ) : (
                <>
                  <a href={form.eng} target="_blank" rel="noopener noreferrer" class="badge" style="text-decoration:none;padding:0.4rem 0.75rem">English</a>
                  <a href={form.spa} target="_blank" rel="noopener noreferrer" class="badge" style="text-decoration:none;padding:0.4rem 0.75rem;background:transparent;border:1px solid var(--gold);color:var(--gold)">Spanish</a>
                </>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Rights & Responsibilities -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Your Rights</span>
        <h2>Patient Rights &amp; Responsibilities</h2>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem" class="responsive-2col">
        <div>
          <h3 style="color:var(--gold);font-size:1rem;margin-bottom:1.25rem">Your Rights</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.6rem">
            {[
              'Be treated with dignity and respect',
              'Fair treatment without discrimination of any kind',
              'Make informed decisions regarding your health care',
              'Refuse treatment and be informed of the consequences',
              'Know the names and roles of all caregivers',
              'Receive information in a language you understand',
              'Access your medical records',
              'Confidentiality of records and communications',
              'Choose another healthcare provider',
              'Receive an explanation of your bill',
              'Appropriate assessment and management of pain',
              'Receive care in a safe environment free from abuse or coercion',
              'Voice concerns and complaints',
              'Give or withhold informed consent',
            ].map(right => (
              <li style="display:flex;align-items:flex-start;gap:0.6rem;color:var(--muted);font-size:0.875rem">
                <span style="color:var(--gold);flex-shrink:0;margin-top:0.1rem">·</span>
                {right}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 style="color:var(--gold);font-size:1rem;margin-bottom:1.25rem">Your Responsibilities</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.6rem">
            {[
              'Provide accurate and complete information about your health',
              'Actively participate in decisions regarding your health care',
              'Keep scheduled appointments or call to reschedule',
              'Ask questions when something is unclear',
              'Follow the treatment plan agreed upon with your provider',
              'Treat all staff and other patients with courtesy and respect',
              'Respect the rights, privacy, and property of others',
              'Promptly meet any financial obligation agreed to with CMC',
            ].map(resp => (
              <li style="display:flex;align-items:flex-start;gap:0.6rem;color:var(--muted);font-size:0.875rem">
                <span style="color:var(--gold);flex-shrink:0;margin-top:0.1rem">·</span>
                {resp}
              </li>
            ))}
          </ul>
          <div style="margin-top:2rem;padding:1.25rem;background:var(--navy-mid);border:1px solid var(--border);border-radius:8px">
            <h4 style="font-size:0.875rem;color:var(--cream);margin:0 0 0.5rem">Patient Privacy</h4>
            <p style="font-size:0.8rem;color:var(--muted);margin:0 0 0.75rem">We value the privacy of every patient. You have rights regarding how your medical information is used and disclosed.</p>
            <a href="https://cmcenters.org/wp-content/uploads/2024/10/2104507_Notice-Of-Privacy_pg9-10-11.pdf" target="_blank" rel="noopener noreferrer" style="font-size:0.8rem;color:var(--gold)">View Privacy Notice →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Payments -->
  <section class="section">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start" class="responsive-2col">
        <div>
          <span class="eyebrow">Billing</span>
          <h2 style="margin-top:0.5rem">Payments &amp; Billing</h2>
          <p style="color:var(--muted)">Our healthcare professionals see all patients, regardless of their ability to pay. Please bring your current insurance or member ID card to every appointment.</p>
          <p style="color:var(--muted)">Depending on your insurance, payment may be required at time of service or billed monthly.</p>
          <p style="margin-top:1.5rem;color:var(--muted);font-size:0.9rem">
            <strong style="color:var(--cream)">Accepted:</strong> Cash · Check · Visa · Mastercard · Discover · American Express
          </p>
          <p style="margin-top:1rem">
            <strong style="color:var(--cream)">Billing Department:</strong><br />
            <a href="tel:2096365550" style="color:var(--gold)">(209) 636-5550</a>
          </p>
        </div>
        <div style="background:var(--navy-mid);border:1px solid var(--border);border-radius:8px;padding:2rem">
          <h3 style="font-size:1rem;margin-bottom:0.75rem;color:var(--gold)">Good Faith Estimate</h3>
          <p style="font-size:0.875rem;color:var(--muted);margin:0 0 0.75rem">You have the right to receive a written cost estimate at least 1 business day before any non-emergency scheduled service. This covers medical items, tests, drugs, equipment, and facility fees.</p>
          <p style="font-size:0.875rem;color:var(--muted);margin:0 0 0.75rem">You may dispute a bill that is $400 or more higher than the estimate you received.</p>
          <p style="font-size:0.875rem;color:var(--muted);margin:0">
            More info: <a href="https://www.cms.gov/nosurprises" target="_blank" rel="noopener noreferrer" style="color:var(--gold)">cms.gov/nosurprises</a> or call <a href="tel:2096365550" style="color:var(--gold)">(209) 636-5550</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Patient-Centered Medical Home -->
  <section class="section" style="background:var(--navy-mid);border-top:1px solid var(--border)">
    <div class="container" style="max-width:760px;text-align:center">
      <span class="eyebrow">Our Approach</span>
      <h2 style="margin-top:0.5rem">Patient-Centered Medical Home</h2>
      <p style="color:var(--muted);font-size:1.05rem;line-height:1.7">CMC is certified as a <strong style="color:var(--cream)">Patient-Centered Medical Home (PCMH)</strong>, meaning we take a team-based approach that puts patients at the center of care. Your care team includes your primary care provider alongside medical, dental, behavioral health professionals, specialty care, and assistance programs — all working together for your health.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:2rem">
        <a href="/providers" class="btn-primary">Find a Provider</a>
        <a href="/locations" class="btn-outline">Find a Location</a>
      </div>
    </div>
  </section>

</Base>

<style>
  @media (max-width: 700px) {
    .responsive-2col {
      grid-template-columns: 1fr !important;
    }
  }
</style>
