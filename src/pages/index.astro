---
import Base from '../layouts/Base.astro';
import locations from '../data/locations.json';
import services from '../data/services.json';
import posts from '../data/posts.json';

const featuredLocations = locations.slice(0, 3);

// Same priority ordering as Services page
const CORE_SERVICES  = ['adult-medicine', 'dental-care', 'behavioral-health'];
const DEMO_SERVICES = ['womens-health', 'pediatrics', 'women-infant-and-children-program-wic'];
function serviceRank(slug) {
  const ci = CORE_SERVICES.indexOf(slug);
  if (ci !== -1) return ci;
  const di = DEMO_SERVICES.indexOf(slug);
  if (di !== -1) return CORE_SERVICES.length + di;
  return CORE_SERVICES.length + DEMO_SERVICES.length;
}
const featuredServices = [...services]
  .sort((a, b) => {
    const ra = serviceRank(a.slug), rb = serviceRank(b.slug);
    if (ra !== rb) return ra - rb;
    return a.title.localeCompare(b.title);
  })
  .slice(0, 6);

// Same sort as News page: newest first
const recentPosts = [...posts]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);

function formatDate(dateStr) {
  return new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const heroPhoto = '/img/hero-home.webp';
---
<Base title="Home" description="Community Medical Centers — Quality, compassionate healthcare for all in the Central Valley since 1968.">
  <link slot="head" rel="preload" as="image" href={heroPhoto} />

  <!-- Hero: full-teal background, floating image card left, text right -->
  <section style="background:var(--teal);overflow:hidden">
    <div style="display:grid;grid-template-columns:1fr 1fr;min-height:520px;align-items:center;max-width:1200px;margin:0 auto;padding:3rem 2rem;gap:3rem" class="hero-split">
      <!-- Photo card -->
      <div style="background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.10)">
        <img
          src={heroPhoto}
          alt="Community Medical Centers — caring for our community"
          style="width:100%;display:block;max-height:440px;object-fit:cover"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <!-- Content side -->
      <div>
        <h1 style="font-size:clamp(2.4rem,4.5vw,3.8rem);color:var(--navy-footer);margin-bottom:1.25rem;font-weight:800;line-height:1.1">
          Healthcare<br>for all
        </h1>
        <p style="font-size:1.05rem;color:rgba(26,54,79,0.8);margin-bottom:2rem;line-height:1.7;max-width:480px">
          Everyone in our community deserves quality healthcare delivered with dignity and respect.
        </p>
        <a href="/services" class="btn btn-primary">Learn More</a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <div class="stats-bar">
    <div class="container">
      <div class="stats-grid">
        <div>
          <div class="stat-number">28</div>
          <div class="stat-label">Clinic Locations</div>
        </div>
        <div>
          <div class="stat-number">150+</div>
          <div class="stat-label">Providers</div>
        </div>
        <div>
          <div class="stat-number">30+</div>
          <div class="stat-label">Languages Spoken</div>
        </div>
        <div>
          <div class="stat-number">55+</div>
          <div class="stat-label">Years of Service</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <div class="section-header">
<h2>Comprehensive Health Services</h2>
      </div>
      <div class="grid-3">
        {featuredServices.map(svc => (
          <a href={`/services/${svc.slug}`} class="card" style="display:flex;flex-direction:column;color:inherit">
            {svc.thumbnail
              ? <img class="card-img" src={svc.thumbnail} alt={svc.title} loading="lazy" />
              : <div style="height:200px;background:var(--teal-light);display:flex;align-items:center;justify-content:center"><span style="color:var(--teal-dark);font-size:2rem">✚</span></div>
            }
            <div class="card-body">
              <h3>{svc.title}</h3>
            </div>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.5rem">
        <a href="/services" class="btn btn-outline">View All Services</a>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Locations -->
  <section class="section" style="padding-top:3rem;padding-bottom:3rem">
    <div class="section-header container">
      <h2>CMC Locations</h2>
    </div>
    <div style="padding:0 12.5%;margin-top:1.5rem">
      {featuredLocations.map(loc => {
        const addr = (loc.meta?.ignyte_location_address || '').replace(/,?\s*USA\s*$/i, '');
        return (
          <a href={`/locations/${loc.slug}`} class="location-row">
            <div class="location-row-main">
              <h2 class="location-row-name">{loc.title}</h2>
              <div class="location-row-meta">
                {addr && <span>{addr}</span>}
                {loc.meta?.ignyte_location_phone && <span>{loc.meta.ignyte_location_phone}</span>}
              </div>
            </div>
            <span class="location-row-arrow" aria-hidden="true">→</span>
          </a>
        );
      })}
    </div>
    <div style="text-align:center;margin-top:2.5rem">
      <a href="/locations" class="btn btn-outline">View All Locations</a>
    </div>
  </section>

  <hr class="divider" />

  <!-- Donate CTA -->
  <section class="section" style="background:var(--teal)">
    <div class="container" style="text-align:center;padding-top:3rem;padding-bottom:3rem">
      <h2 style="color:var(--navy-footer);margin-bottom:1rem">Support Our Mission</h2>
      <p style="font-size:1.05rem;color:rgba(26,54,79,0.85);max-width:560px;margin:0 auto 2rem">
        Your gift helps ensure vulnerable patients continue to receive high-quality, essential care and services.
      </p>
      <a href="https://communitymedicalcenters.networkforgood.com/projects/198038-communitymedical-center-inc-general-giving" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Donate Now</a>
    </div>
  </section>

  <hr class="divider" />

  <!-- News -->
  {recentPosts.length > 0 && (
    <section class="section">
      <div class="container" style="text-align:center">
        <div class="section-header">
          <h2>News</h2>
        </div>
        <div class="grid-3" style="text-align:left">
          {recentPosts.map(post => {
            const cat = post.terms?.category?.[0] || '';
            return (
            <a href={`/news/${post.slug}`} class="card" style="display:block;color:inherit" data-category={cat}>
              {post.thumbnail && <img class="card-img" src={post.thumbnail} alt={post.title} loading="lazy" />}
              <div class="card-body">
                {cat && <div class="card-eyebrow">{cat}</div>}
                <h3>{post.title}</h3>
                <div style="font-size:0.78rem;color:var(--text-muted);margin-top:0.5rem">{formatDate(post.date)}</div>
              </div>
            </a>
            );
          })}
        </div>
        <div style="margin-top:2.5rem">
          <a href="/news" class="btn btn-outline">All News</a>
        </div>
      </div>
    </section>
  )}


</Base>

<style>
  @media (max-width: 768px) {
    .hero-split {
      grid-template-columns: 1fr !important;
      padding: 2rem 1.25rem !important;
      gap: 1.5rem !important;
    }
  }
</style>
