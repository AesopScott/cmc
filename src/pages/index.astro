---
import Base from '../layouts/Base.astro';
import locations from '../data/locations.json';
import services from '../data/services.json';
import posts from '../data/posts.json';

const featuredLocations = locations.slice(0, 3);
const featuredServices = services.slice(0, 6);
const recentPosts = posts.slice(0, 3);

function formatDate(dateStr) {
  return new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const heroPhoto = '/img/hero-home.jpg';
---
<Base title="Home" description="Community Medical Centers — Quality, compassionate healthcare for all in the Central Valley since 1968.">

  <!-- Hero: split layout matching live site -->
  <section style="background:var(--teal);overflow:hidden">
    <div style="display:grid;grid-template-columns:1fr 1fr;min-height:520px" class="hero-split">
      <!-- Photo side -->
      <div style="position:relative;overflow:hidden;min-height:320px">
        <img
          src={heroPhoto}
          alt="Community Medical Centers — caring for our community"
          style="width:100%;height:100%;object-fit:cover;display:block"
          loading="eager"
        />
      </div>
      <!-- Content side -->
      <div style="display:flex;align-items:center;padding:4rem 3.5rem;background:var(--teal)">
        <div>
          <h1 style="font-size:clamp(1.9rem,3.5vw,2.9rem);color:var(--navy-footer);margin-bottom:1.25rem;font-weight:700;line-height:1.2">
            Healthcare for <em style="font-style:normal;color:#fff">every</em> member of our community
          </h1>
          <p style="font-size:1.05rem;color:rgba(26,54,79,0.8);margin-bottom:2rem;line-height:1.7;max-width:480px">
            Community Medical Centers provides quality, compassionate care to all patients — regardless of their ability to pay.
          </p>
          <div style="display:flex;gap:1rem;flex-wrap:wrap">
            <a href="/about" class="btn btn-primary">About CMC</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <div class="stats-bar">
    <div class="container">
      <div class="stats-grid">
        <div>
          <div class="stat-number">20+</div>
          <div class="stat-label">Clinic Locations</div>
        </div>
        <div>
          <div class="stat-number">150+</div>
          <div class="stat-label">Providers</div>
        </div>
        <div>
          <div class="stat-number">30+</div>
          <div class="stat-label">Languages Spoken</div>
        </div>
        <div>
          <div class="stat-number">55+</div>
          <div class="stat-label">Years of Service</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">What We Offer</span>
        <h2>Comprehensive Health Services</h2>
      </div>
      <div class="grid-3">
        {featuredServices.map(svc => (
          <a href={`/services/${svc.slug}`} class="card" style="display:flex;flex-direction:column;color:inherit">
            {svc.thumbnail
              ? <img class="card-img" src={svc.thumbnail} alt={svc.title} loading="lazy" />
              : <div style="height:200px;background:var(--teal-light);display:flex;align-items:center;justify-content:center"><span style="color:var(--teal-dark);font-size:2rem">✚</span></div>
            }
            <div class="card-body">
              <h3>{svc.title}</h3>
            </div>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.5rem">
        <a href="/services" class="btn btn-outline">View All Services</a>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Locations -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Close to Home</span>
        <h2>Locations Throughout the Central Valley</h2>
      </div>
      <div class="grid-3">
        {featuredLocations.map(loc => (
          <a href={`/locations/${loc.slug}`} class="card" style="display:block;color:inherit">
            {loc.thumbnail && <img class="card-img" src={loc.thumbnail} alt={loc.title} loading="lazy" />}
            <div class="card-body">
              <h3>{loc.title}</h3>
              {loc.meta?.ignyte_location_phone && (
                <div class="location-info">
                  <div class="location-info-row">{loc.meta.ignyte_location_phone}</div>
                </div>
              )}
              {loc.meta?.ignyte_location_address && (
                <div class="location-info-row" style="font-size:0.82rem;margin-top:0.25rem">{loc.meta.ignyte_location_address}</div>
              )}
            </div>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.5rem">
        <a href="/locations" class="btn btn-outline">View All Locations</a>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- News -->
  {recentPosts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">Latest</span>
          <h2>News &amp; Stories</h2>
        </div>
        <div class="grid-3">
          {recentPosts.map(post => (
            <a href={`/news/${post.slug}`} class="card" style="display:block;color:inherit">
              {post.thumbnail && <img class="card-img" src={post.thumbnail} alt={post.title} loading="lazy" />}
              <div class="card-body">
                {post.terms?.category?.[0] && <div class="card-eyebrow">{post.terms.category[0]}</div>}
                <h3>{post.title}</h3>
                {post.excerpt && <p style="margin-top:0.5rem">{post.excerpt}</p>}
                <div style="font-size:0.8rem;color:var(--text-muted);margin-top:0.75rem">{formatDate(post.date)}</div>
              </div>
            </a>
          ))}
        </div>
        <div style="text-align:center;margin-top:2.5rem">
          <a href="/news" class="btn btn-outline">All News &amp; Events</a>
        </div>
      </div>
    </section>
  )}


</Base>

<style>
  @media (max-width: 768px) {
    .hero-split {
      grid-template-columns: 1fr !important;
    }
  }
</style>
