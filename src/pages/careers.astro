---
import Base from '../layouts/Base.astro';
import careers from '../data/careers.json';
const { benefits, faqs } = careers;
---
<Base title="Careers" description="Join the Community Medical Centers team. View open positions for providers and all other staff.">

  <!-- Join Us -->
  <section class="section">
    <div class="container" style="text-align:center">
      <h1 style="font-size:clamp(1.8rem,3.5vw,2.6rem);margin-bottom:1.25rem">Join Us</h1>
      <p style="font-size:1.05rem;color:var(--text-muted);line-height:1.8;max-width:760px;margin:0 auto">
        A job at CMC is more than just a career. It's an opportunity to make a difference in your community. We are a mission-driven team committed to providing quality healthcare to everyone in our community.
      </p>
    </div>
  </section>

  <hr class="divider" />

  <!-- Job Boards -->
  <section class="section">
    <div class="container" style="text-align:center">
      <div class="grid-2" style="gap:2rem;text-align:left">
        <div class="card" style="display:flex;flex-direction:column">
          <div style="height:8px;background:var(--teal-dark)"></div>
          <div class="card-body" style="flex:1;display:flex;flex-direction:column;gap:1rem">
            <h2 style="font-size:1.15rem">Provider Positions</h2>
            <p style="color:var(--text-muted);font-size:0.9rem;flex:1">Physicians, nurse practitioners, dentists, behavioral health providers, and other clinical roles.</p>
            <a href="https://jobs.inline.group/cmc/" target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="align-self:flex-start">View Provider Jobs</a>
          </div>
        </div>
        <div class="card" style="display:flex;flex-direction:column">
          <div style="height:8px;background:var(--teal-dark)"></div>
          <div class="card-body" style="flex:1;display:flex;flex-direction:column;gap:1rem">
            <h2 style="font-size:1.15rem">All Other Positions</h2>
            <p style="color:var(--text-muted);font-size:0.9rem;flex:1">Administrative, support, and non-clinical roles across all CMC locations.</p>
            <a href="https://www.paycomonline.net/v4/ats/web.php/jobs?clientkey=2121B43BA8B8BCA134017BE7125D3DCC" target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="align-self:flex-start">View All Jobs</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Benefits -->
  <section class="section">
    <div class="container" style="text-align:center">
      <div class="section-header">
        <h2>Benefits</h2>
      </div>
      <div style="margin-top:1.5rem;display:flex;flex-direction:column;gap:1.25rem;text-align:left">
        {benefits.map(b => (
          <div style="display:flex;gap:1rem;align-items:flex-start;padding:1.25rem 0;border-bottom:1px solid var(--border)">
            <div>
              <div style="font-weight:600;font-size:1rem;color:var(--text);margin-bottom:0.3rem">{b.title}</div>
              <div style="font-size:0.9rem;color:var(--text-muted);line-height:1.6">{b.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="text-align:center">
      <div class="section-header">
        <h2>Frequently Asked Questions</h2>
      </div>
      <div style="margin-top:2rem;display:flex;flex-direction:column;gap:0;text-align:left" class="faq-list">
        {faqs.map(faq => (
          <details class="faq-item">
            <summary class="faq-question">{faq.q}</summary>
            <div class="faq-answer">
              {faq.list
                ? <ul style="list-style:none;display:flex;flex-direction:column;gap:0.4rem;padding:0">
                    {faq.a.split('\n').map(line => (
                      <li style="display:flex;gap:0.5rem">
                        <span style="color:var(--teal-dark);flex-shrink:0">-</span>
                        {faq.html
                          ? <span set:html={line} />
                          : line
                        }
                      </li>
                    ))}
                  </ul>
                : faq.a
              }
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

</Base>

<style>
  .faq-item { border-bottom: 1px solid var(--border); }
  .faq-item:first-child { border-top: 1px solid var(--border); }
  .faq-question {
    list-style: none;
    padding: 1.1rem 0;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text);
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after { content: '+'; font-size: 1.2rem; color: var(--teal-dark); flex-shrink: 0; margin-left: 1rem; }
  details[open] .faq-question::after { content: '-'; }
  .faq-answer { padding: 0 0 1.1rem; font-size: 0.9rem; color: var(--text-muted); line-height: 1.7; }
</style>
