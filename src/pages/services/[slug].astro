---
import Base from '../../layouts/Base.astro';
import services from '../../data/services.json';
import locations from '../../data/locations.json';
import { stripWpBlocks } from '../../utils/content.js';

export function getStaticPaths() {
  return services.map(svc => ({ params: { slug: svc.slug }, props: { svc } }));
}

const { svc } = Astro.props;

const content = stripWpBlocks(svc.content || '');

// Locations where this service is offered
const svcLocIds = Object.keys(svc.meta?.['ignyte_locations[]'] || {}).map(Number);
const svcLocations = locations
  .filter(loc => svcLocIds.includes(loc.id))
  .sort((a, b) => a.title.localeCompare(b.title));
---
<Base title={svc.title} description={`${svc.title} services at Community Medical Centers.`}>

  <div class="page-header">
    <div class="container">
      <div class="breadcrumb"><a href="/services">Services</a> / {svc.title}</div>
      <h1>{svc.title}</h1>
    </div>
  </div>

  <section class="section">
    <div class="container" style="max-width:900px">
      <div class="post-content" set:html={content} />

      {svcLocations.length > 0 && (
        <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid var(--border)">
          <h2 style="font-size:1.3rem;margin-bottom:1.25rem">Where to Get This Service</h2>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:0.75rem">
            {svcLocations.map(loc => (
              <a href={`/locations/${loc.slug}`} class="loc-svc-card">
                <div class="loc-svc-name">{loc.title}</div>
                {loc.meta?.ignyte_location_address && (
                  <div class="loc-svc-detail">{loc.meta.ignyte_location_address.replace(/,?\s*USA\s*$/i,'')}</div>
                )}
                {loc.meta?.ignyte_location_phone && (
                  <div class="loc-svc-detail">{loc.meta.ignyte_location_phone}</div>
                )}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

</Base>

<style>
  .loc-svc-card {
    display: block;
    padding: 1rem 1.25rem;
    background: var(--teal-light);
    border: 1px solid rgba(38,122,112,0.2);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s, border-color 0.15s;
  }
  .loc-svc-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.09);
    border-color: var(--teal-dark);
    filter: none;
  }
  .loc-svc-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--teal-dark);
    margin-bottom: 0.3rem;
  }
  .loc-svc-detail {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.5;
  }
</style>
