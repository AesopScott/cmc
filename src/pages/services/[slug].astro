---
import Base from '../../layouts/Base.astro';
import services from '../../data/services.json';
import locations from '../../data/locations.json';
import { stripWpBlocks } from '../../utils/content.js';

export function getStaticPaths() {
  return services.map(svc => ({ params: { slug: svc.slug }, props: { svc } }));
}

const { svc } = Astro.props;

const content = stripWpBlocks(svc.content || '');

// Locations where this service is offered
const svcLocIds = Object.keys(svc.meta?.['ignyte_locations[]'] || {}).map(Number);
const svcLocations = locations
  .filter(loc => svcLocIds.includes(loc.id))
  .sort((a, b) => a.title.localeCompare(b.title));
---
<Base title={svc.title} description={`${svc.title} services at Community Medical Centers.`}>

  <div class="page-header">
    <div class="container">
      <h1>{svc.title}</h1>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="post-content" set:html={content} />

      {svcLocations.length > 0 && (
        <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid var(--border)">
          <h2 style="font-size:1.3rem;margin-bottom:1.25rem">Locations Offering This Service</h2>
          <ul class="svc-locations-list">
            {svcLocations.map(loc => (
              <li>
                <a href={`/locations/${loc.slug}`}>{loc.title}</a>
                {loc.meta?.ignyte_location_address && (
                  <span class="svc-loc-address">{loc.meta.ignyte_location_address.replace(/,?\s*USA\s*$/i,'')}</span>
                )}
                {loc.meta?.ignyte_location_phone && (
                  <span class="svc-loc-phone">{loc.meta.ignyte_location_phone}</span>
                )}
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>

</Base>

<style>
  .svc-locations-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .svc-locations-list li {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border);
  }
  .svc-locations-list a {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--teal-dark);
    text-decoration: none;
  }
  .svc-locations-list a:hover {
    text-decoration: underline;
  }
  .svc-loc-address,
  .svc-loc-phone {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
</style>
