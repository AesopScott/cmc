---
import Base from '../../layouts/Base.astro';
import services from '../../data/services.json';
import { stripWpBlocks } from '../../utils/content.js';

export function getStaticPaths() {
  return services.map(svc => ({ params: { slug: svc.slug }, props: { svc } }));
}

const { svc } = Astro.props;

const content = stripWpBlocks(svc.content || '');
---
<Base title={svc.title} description={`${svc.title} services at Community Medical Centers.`}>

  <div class="page-header">
    <div class="container">
      <div class="breadcrumb"><a href="/services">Services</a> / {svc.title}</div>
      <h1>{svc.title}</h1>
    </div>
  </div>

  {svc.thumbnail && (
    <div style="width:100%;max-height:360px;overflow:hidden">
      <img src={svc.thumbnail} alt={svc.title} style="width:100%;height:360px;object-fit:cover" />
    </div>
  )}

  <section class="section">
    <div class="container">
      <div class="post-content" set:html={content} />

      <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid var(--border);text-align:center">
        <h2 style="margin-bottom:1rem">Ready to get started?</h2>
        <p style="color:var(--muted);margin-bottom:1.5rem">Our team is here to help. Call us to schedule an appointment at a location near you.</p>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
          <a href="tel:2099444700" class="btn btn-primary">(209) 944-4700</a>
          <a href="/locations" class="btn btn-outline">Find a Location</a>
        </div>
      </div>
    </div>
  </section>

</Base>
