---
import Base from '../../layouts/Base.astro';
import services from '../../data/services.json';
---
<Base title="Services" description="Community Medical Centers offers comprehensive healthcare services including primary care, dental, behavioral health, and more.">

  <section class="section" style="padding-top:3rem">
    <div class="container">
      <div class="grid-3">
        {services.map(svc => (
          <a href={`/services/${svc.slug}`} class="card" style="display:flex;flex-direction:column;color:inherit">
            {svc.thumbnail
              ? <img class="card-img" src={svc.thumbnail} alt={svc.title} loading="lazy" />
              : <div style="height:200px;background:var(--teal-light);display:flex;align-items:center;justify-content:center"><span style="color:var(--teal-dark);font-size:2rem">✚</span></div>
            }
            <div class="card-body">
              <h3>{svc.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Base>
