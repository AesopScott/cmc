---
import Base from '../../layouts/Base.astro';
import services from '../../data/services.json';
---
<Base title="Services" description="Community Medical Centers offers comprehensive healthcare services including primary care, dental, behavioral health, and more.">

  <section class="section" style="padding-top:3rem">
    <div class="container">
      <div class="grid-3" style="align-items:start">
        {services.map(svc => (
          <a href={`/services/${svc.slug}`} class="card" style="display:block;color:inherit">
            {svc.thumbnail
              ? <img class="card-img" src={svc.thumbnail} alt={svc.title} loading="lazy" />
              : <div style="height:6px;background:var(--teal-dark)"></div>
            }
            <div class="card-body">
              <h3>{svc.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Base>
