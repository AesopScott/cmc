---
import Base from '../../layouts/Base.astro';
import providers from '../../data/providers.json';
import locations from '../../data/locations.json';

export function getStaticPaths() {
  return providers.map(p => ({ params: { slug: p.slug }, props: { provider: p } }));
}

const { provider: p } = Astro.props;
const meta = p.meta || {};

const specialty = p.terms?.ignyte_specialty?.[0] || '';
const langs = p.terms?.ignyte_lang || [];
const position = meta['ignyte-provider-position'] || '';

// Resolve location names
const providerLocations = (() => {
  const locMap = meta['ignyte_locations[]'];
  if (!locMap || typeof locMap !== 'object') return [];
  return Object.entries(locMap)
    .filter(([, name]) => name)
    .map(([id, name]) => {
      const loc = locations.find(l => String(l.id) === String(id));
      return { name: loc?.title || String(name), slug: loc?.slug || null };
    });
})();
---
<Base title={p.title} description={`${p.title}, ${position} — Community Medical Centers provider.`}>

  <section class="section">
    <div class="container">
      <div style="display:grid;grid-template-columns:220px 1fr;gap:3rem;align-items:start" class="provider-detail-grid">

        <!-- Circular Photo -->
        <div style="text-align:center">
          <div class="provider-detail-circle">
            <img
              src={p.thumbnail || '/img/provider-placeholder.svg'}
              alt={p.title}
              class="provider-detail-img"
            />
          </div>
        </div>

        <!-- Details -->
        <div>
          <h1 style="font-size:1.75rem;margin-bottom:0.1rem">{p.title}{position ? `, ${position}` : ''}</h1>

          {specialty && (
            <div style="margin-bottom:1.5rem;margin-top:1.25rem">
              <div style="font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);margin-bottom:0.4rem">Specialty</div>
              <div>{specialty}</div>
            </div>
          )}

          {langs.length > 0 && (
            <div style="margin-bottom:1.5rem">
              <div style="font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);margin-bottom:0.4rem">Languages</div>
              <div class="provider-tags">
                {langs.map(l => <span class="badge">{l}</span>)}
              </div>
            </div>
          )}

          {providerLocations.length > 0 && (
            <div style="margin-bottom:1.5rem">
              <div style="font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);margin-bottom:0.4rem">Locations</div>
              <ul style="list-style:none;display:flex;flex-direction:column;gap:0.4rem">
                {providerLocations.map(loc => (
                  <li>
                    {loc.slug
                      ? <a href={`/locations/${loc.slug}`} style="color:var(--teal-dark);font-weight:500">{loc.name}</a>
                      : <span style="color:var(--muted)">{loc.name}</span>
                    }
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

      </div>
    </div>
  </section>

</Base>

<style>
  .provider-detail-circle {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--teal-light);
    margin: 0 auto;
  }
  .provider-detail-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  @media (max-width: 700px) {
    .provider-detail-grid { grid-template-columns: 1fr !important; }
  }
</style>
