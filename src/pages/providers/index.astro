---
import Base from '../../layouts/Base.astro';
import providers from '../../data/providers.json';
import taxonomies from '../../data/taxonomies.json';

const specialties = taxonomies.ignyte_specialty.filter(s => s.count > 0).map(s => s.name);
---
<Base title="Providers" description="Find a Community Medical Centers healthcare provider near you.">

  <div class="page-header">
    <div class="container">
      <h1>Our Providers</h1>
      <p>Meet the dedicated physicians, nurse practitioners, and specialists who serve our community.</p>
    </div>
  </div>

  <div class="filter-bar" role="search" aria-label="Search providers">
    <div class="filter-inner">
      <label for="search" class="sr-only">Search by provider name</label>
      <input type="text" id="search" placeholder="Search by name..." style="flex:1;min-width:200px" />
      <label for="specialty-filter" class="sr-only">Filter by specialty</label>
      <select id="specialty-filter">
        <option value="">All Specialties</option>
        {specialties.map(s => <option value={s}>{s}</option>)}
      </select>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="grid-4" id="provider-grid">
        {providers.map(p => {
          const specialty = p.terms?.ignyte_specialty?.[0] || '';
          const langs = (p.terms?.ignyte_lang || []).join(', ');
          return (
            <a href={`/providers/${p.slug}`} class="card" style="display:flex;flex-direction:column"
               data-name={p.title.toLowerCase()}
               data-specialty={specialty.toLowerCase()}>
              <img class="provider-photo" src={p.thumbnail || '/img/placeholder-provider.jpg'} alt={p.title} loading="lazy" />
              <div class="card-body" style="flex:1;display:flex;flex-direction:column">
                <div class="provider-name" style="font-size:clamp(0.85rem,1.5vw,1rem);line-height:1.3;word-break:break-word">{p.title}</div>
                <div class="provider-title" style="margin-top:0.25rem">{p.meta?.['ignyte-provider-position']}</div>
                <div style="margin-top:auto;padding-top:0.5rem">
                  {specialty && <div class="badge">{specialty}</div>}
                  {langs && <div style="font-size:0.75rem;color:var(--muted);margin-top:0.5rem">{langs}</div>}
                </div>
              </div>
            </a>
          );
        })}
      </div>
      <p id="no-results" style="display:none;text-align:center;color:var(--muted);padding:3rem 0">No providers match your search.</p>
      <p id="result-count" aria-live="polite" aria-atomic="true" class="sr-only"></p>
    </div>
  </section>

  <script>
    const search = document.getElementById('search');
    const specialtyFilter = document.getElementById('specialty-filter');
    const cards = document.querySelectorAll('#provider-grid .card');
    const noResults = document.getElementById('no-results');

    const resultCount = document.getElementById('result-count');

    function filter() {
      const q = search.value.toLowerCase();
      const sp = specialtyFilter.value.toLowerCase();
      let visible = 0;
      cards.forEach(card => {
        const matchName = !q || card.dataset.name.includes(q);
        const matchSpec = !sp || card.dataset.specialty.includes(sp);
        const show = matchName && matchSpec;
        card.style.display = show ? 'flex' : 'none';
        if (show) visible++;
      });
      noResults.style.display = visible === 0 ? 'block' : 'none';
      resultCount.textContent = visible === 0 ? 'No providers found.' : `${visible} provider${visible === 1 ? '' : 's'} found.`;
    }

    search.addEventListener('input', filter);
    specialtyFilter.addEventListener('change', filter);
  </script>

</Base>
