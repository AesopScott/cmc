---
import Base from '../../layouts/Base.astro';
import posts from '../../data/posts.json';
import { stripWpBlocks, formatDate } from '../../utils/content.js';

export function getStaticPaths() {
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;

const content = stripWpBlocks(post.content || '');
const category = post.terms?.category?.[0] || '';
---
<Base title={post.title} description={post.excerpt || `${post.title} — Community Medical Centers news.`}>

  <div class="page-header">
    <div class="container">
      <div class="breadcrumb"><a href="/news">News</a> / {category || 'Article'}</div>
      <h1 style="max-width:760px">{post.title}</h1>
      <div style="display:flex;gap:1rem;align-items:center;margin-top:1rem;flex-wrap:wrap">
        {category && <span class="badge">{category}</span>}
        <span style="font-size:0.82rem;color:var(--muted)">{formatDate(post.date)}</span>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {post.thumbnail && (
        <img class="post-img" src={post.thumbnail} alt={post.title} />
      )}
      <div class="post-content" set:html={content} />

      <div style="margin-top:3rem;padding-top:2rem;border-top:1px solid var(--border)">
        <a href="/news" class="btn btn-outline">&larr; Back to News</a>
      </div>
    </div>
  </section>

</Base>
