---
import Base from '../../layouts/Base.astro';
import posts from '../../data/posts.json';

const categories = [...new Set(posts.flatMap(p => p.terms?.category || []))].filter(Boolean);

const sorted = [...posts].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

function formatDate(dateStr) {
  return new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<Base title="News" description="The latest news from Community Medical Centers.">

  <div class="filter-bar" role="search" aria-label="Filter news by category">
    <div class="filter-inner">
      <label for="cat-filter" class="sr-only">Filter by category</label>
      <select id="cat-filter">
        <option value="">All Categories</option>
        {categories.map(c => <option value={c}>{c}</option>)}
      </select>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="grid-3" id="posts-grid">
        {sorted.map(post => {
          const cat = post.terms?.category?.[0] || '';
          return (
            <a href={`/news/${post.slug}`} class="card" style="display:block" data-category={cat}>
              {post.thumbnail && <img class="card-img" src={post.thumbnail} alt={post.title} loading="lazy" />}
              <div class="card-body">
                {cat && <div class="card-eyebrow">{cat}</div>}
                <h3>{post.title}</h3>
                <div style="font-size:0.78rem;color:var(--text-muted);margin-top:0.5rem">{formatDate(post.date)}</div>
              </div>
            </a>
          );
        })}
      </div>
      <p id="no-posts" style="display:none;text-align:center;color:var(--muted);padding:3rem 0">No posts in this category.</p>
      <p id="result-count" aria-live="polite" aria-atomic="true" class="sr-only"></p>
    </div>
  </section>

  <script>
    const filter = document.getElementById('cat-filter');
    const cards = document.querySelectorAll('#posts-grid .card');
    const noResults = document.getElementById('no-posts');
    const resultCount = document.getElementById('result-count');
    filter.addEventListener('change', () => {
      const val = filter.value;
      let visible = 0;
      cards.forEach(card => {
        const show = !val || card.dataset.category === val;
        card.style.display = show ? 'block' : 'none';
        if (show) visible++;
      });
      noResults.style.display = visible === 0 ? 'block' : 'none';
      resultCount.textContent = visible === 0 ? 'No posts found.' : `${visible} post${visible === 1 ? '' : 's'} found.`;
    });
  </script>

</Base>
