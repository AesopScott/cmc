---
import Base from '../../layouts/Base.astro';

const forms = [
  {
    title: 'Patient Registration',
    eng: 'https://cmcenters.org/wp-content/uploads/2026/03/ENG_Patient-Registration_FINAL-05-09-25.pdf',
    spa: 'https://cmcenters.org/wp-content/uploads/2025/05/SPA_Patient-Registration_FINAL-05-09-25.pdf',
  },
  {
    title: 'Advance Directive',
    eng: 'https://cmcenters.org/wp-content/uploads/2026/03/ENG_Advance-Directive-Acknowledgement_Rev-3-2024.pdf',
    spa: 'https://cmcenters.org/wp-content/uploads/2025/03/SPA_Advance-Directive-Acknowledgement_Rev-11-2025.pdf',
  },
  {
    title: 'Medicare Annual Wellness Visit Health Risk Assessment',
    eng: 'https://cmcenters.org/wp-content/uploads/2026/03/Medicare-AWV-Health-Risk-Assessment-_ENGLISH.pdf',
    spa: 'https://cmcenters.org/wp-content/uploads/2026/03/Medicare-AWV-Health-Risk-Assessment_SPANISH.pdf',
  },
  {
    title: 'Medical Records Request',
    eng: 'https://cmcenters.org/wp-content/uploads/2026/03/ENG_Medical-Records-Request_FINAL-05-2025.pdf',
    spa: 'https://cmcenters.org/wp-content/uploads/2025/08/SPA_Medical-Records-Request_FINAL-05-2025.pdf',
  },
  {
    title: 'Sliding Fee Discount Application',
    eng: 'https://cmcenters.org/wp-content/uploads/2026/03/ENG_Sliding-Fee-Discount-Application_FINAL-07-2025.pdf',
    spa: 'https://cmcenters.org/wp-content/uploads/2025/08/SPA_Sliding-Fee-Discount-Application_FINAL-07-2025.pdf',
  },
  {
    title: 'Patient Complaint Form',
    jotform: 'https://form.jotform.com/240815529548060',
  },
];
---
<Base title="Patient Forms" description="Download patient registration, medical records, sliding fee, and other forms in English and Spanish.">

  <div class="page-header">
    <div class="container">
      <div class="breadcrumb"><a href="/">Home</a> / <a href="/patients">Patients</a> / Patient Forms</div>
      <h1>Patient Forms</h1>
      <p>All forms are available in English and Spanish. Download, complete, and bring to your appointment or submit as instructed.</p>
    </div>
  </div>

  <section class="section" style="padding-top:2.5rem">
    <div class="container" style="max-width:860px">
      <div style="display:flex;flex-direction:column;gap:0.75rem">
        {forms.map(form => (
          <div class="form-row">
            <div class="form-row-title">{form.title}</div>
            <div class="form-row-actions">
              {form.jotform ? (
                <a href={form.jotform} target="_blank" rel="noopener noreferrer" class="form-btn form-btn--primary">Open Form</a>
              ) : (
                <>
                  <a href={form.eng} target="_blank" rel="noopener noreferrer" class="form-btn form-btn--primary">English PDF</a>
                  <a href={form.spa} target="_blank" rel="noopener noreferrer" class="form-btn form-btn--secondary">Spanish PDF</a>
                </>
              )}
            </div>
          </div>
        ))}
      </div>

      <div style="margin-top:2.5rem;padding:1.5rem;background:var(--bg-alt);border-radius:8px;border:1px solid var(--border);font-size:0.875rem;color:var(--text-muted)">
        <strong style="color:var(--text)">Need help with forms?</strong> Contact the Health Information Department at <a href="tel:2095463870" style="color:var(--teal-dark)">(209) 546-3870</a>, or submit medical records requests by fax to <a href="fax:2097626808" style="color:var(--teal-dark)">(209) 762-6808</a> or email <a href="mailto:prforms@cmcenters.org" style="color:var(--teal-dark)">prforms@cmcenters.org</a>.
      </div>
    </div>
  </section>

</Base>

<style>
  .form-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.1rem 1.4rem;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .form-row-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
    flex: 1;
  }
  .form-row-actions {
    display: flex;
    gap: 0.6rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }
  .form-btn {
    display: inline-block;
    padding: 0.4rem 0.9rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.15s;
  }
  .form-btn--primary { background: var(--teal-dark); color: #fff; }
  .form-btn--primary:hover { background: #1e6b62; color: #fff; filter: none; }
  .form-btn--secondary { border: 1.5px solid var(--teal-dark); color: var(--teal-dark); background: transparent; }
  .form-btn--secondary:hover { background: var(--teal-light); filter: none; }
  @media (max-width: 600px) {
    .form-row { flex-direction: column; align-items: flex-start; }
  }
</style>
