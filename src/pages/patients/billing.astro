---
import Base from '../../layouts/Base.astro';
---
<Base title="Payments & Billing" description="Billing, payment options, Good Faith Estimate, and sliding fee discount information at Community Medical Centers.">

  <div class="page-header">
    <div class="container">
      <div class="breadcrumb"><a href="/">Home</a> / <a href="/patients">Patients</a> / Payments &amp; Billing</div>
      <h1>Payments &amp; Billing</h1>
    </div>
  </div>

  <section class="section">
    <div class="container" style="max-width:900px">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start" class="responsive-2col">

        <div>
          <p style="color:var(--text-muted);margin-bottom:1.25rem">Our healthcare professionals see all patients, regardless of their ability to pay. Please bring your current insurance or member ID card to every appointment.</p>
          <p style="color:var(--text-muted);margin-bottom:1.25rem">Depending on your insurance, payment may be required at time of service or billed monthly.</p>

          <div style="margin-bottom:1.5rem">
            <div style="font-size:0.75rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--teal-dark);margin-bottom:0.4rem">Accepted Payment Methods</div>
            <p style="font-size:0.9rem;color:var(--text-muted);margin:0">Cash · Check · Visa · Mastercard · Discover · American Express</p>
          </div>

          <div style="padding:1.25rem 1.5rem;background:var(--teal-light);border-radius:8px;border:1px solid rgba(38,122,112,0.2)">
            <div style="font-size:0.75rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--teal-dark);margin-bottom:0.4rem">Billing Department</div>
            <a href="tel:2096365550" style="font-size:1.1rem;font-weight:600;color:var(--teal-dark)">(209) 636-5550</a>
          </div>

          <div style="margin-top:1.5rem">
            <a href="/patients/patient-forms" style="font-size:0.875rem;color:var(--teal-dark);font-weight:600">Download Sliding Fee Discount Application →</a>
          </div>
        </div>

        <div style="background:var(--bg-alt);border:1px solid var(--border);border-radius:8px;padding:2rem">
          <h2 style="font-size:1rem;margin-bottom:0.75rem;color:var(--text)">Good Faith Estimate</h2>
          <p style="font-size:0.875rem;color:var(--text-muted);margin:0 0 0.75rem">You have the right to receive a written cost estimate at least 1 business day before any non-emergency scheduled service. This covers medical items, tests, drugs, equipment, and facility fees.</p>
          <p style="font-size:0.875rem;color:var(--text-muted);margin:0 0 0.75rem">You may dispute a bill that is $400 or more higher than the estimate you received.</p>
          <p style="font-size:0.875rem;color:var(--text-muted);margin:0">
            More info: <a href="https://www.cms.gov/nosurprises" target="_blank" rel="noopener noreferrer" style="color:var(--teal-dark)">cms.gov/nosurprises</a> or call <a href="tel:2096365550" style="color:var(--teal-dark)">(209) 636-5550</a>
          </p>
        </div>

      </div>
    </div>
  </section>

</Base>

<style>
  @media (max-width: 700px) {
    .responsive-2col { grid-template-columns: 1fr !important; }
  }
</style>
