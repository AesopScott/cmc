---
import Base from '../../layouts/Base.astro';
---
<Base title="Insurance & Coverage" description="Health coverage assistance at Community Medical Centers. We serve all patients regardless of ability to pay.">

  <div class="page-header">
    <div class="container">
      <div class="breadcrumb"><a href="/">Home</a> / <a href="/patients">Patients</a> / Insurance &amp; Coverage</div>
      <h1>Insurance &amp; Coverage</h1>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start" class="responsive-2col">
        <div>
          <p style="color:var(--text-muted);margin-bottom:1.25rem">CMC serves all patients regardless of their ability to pay. Our staff can help you enroll in coverage — no appointment needed.</p>
          <p style="color:var(--text-muted);margin-bottom:1.25rem">Please bring your insurance ID card and any required copayments to your appointment.</p>
          <div style="margin-top:1.5rem;padding:1.25rem 1.5rem;background:var(--teal-light);border-radius:8px;border:1px solid rgba(38,122,112,0.2)">
            <div style="font-size:0.75rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--teal-dark);margin-bottom:0.5rem">Need Enrollment Help?</div>
            <p style="font-size:0.9rem;color:var(--text-muted);margin:0 0 0.5rem">Certified Enrollment Counselors are available:</p>
            <a href="tel:2093732824" style="font-size:1.1rem;font-weight:600;color:var(--teal-dark)">(209) 373-2824</a>
          </div>
        </div>

        <div style="background:var(--bg-alt);border:1px solid var(--border);border-radius:8px;padding:2rem">
          <h2 style="font-size:1rem;margin-bottom:1.25rem;color:var(--text)">Insurance Accepted</h2>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.75rem">
            {[
              'Medi-Cal',
              'Medi-Cal Managed Care (Health Plan of San Joaquin, Health Net, Partnership Health Plan of California)',
              'Medicare',
              'Medicare Advantage Plans',
              'Covered California',
            ].map(ins => (
              <li style="display:flex;align-items:flex-start;gap:0.6rem;color:var(--text-muted);font-size:0.9rem">
                <span style="color:var(--teal-dark);flex-shrink:0;margin-top:0.15rem">✓</span>
                {ins}
              </li>
            ))}
          </ul>
          <div style="margin-top:1.5rem;padding-top:1.25rem;border-top:1px solid var(--border)">
            <p style="font-size:0.875rem;color:var(--text-muted);margin:0">
              <strong>Uninsured?</strong> Depending on your family size, income, and housing, you may qualify for free or low-cost care. Our <a href="/services/enrollment-assistance" style="color:var(--teal-dark)">Health Coverage Counselors</a> can help.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  @media (max-width: 700px) {
    .responsive-2col { grid-template-columns: 1fr !important; }
  }
</style>
