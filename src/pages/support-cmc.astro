---
import Base from '../layouts/Base.astro';

const tiers = [
  {
    name: 'CMC Friend',
    range: '$500 – $1,000',
    color: 'var(--teal-light)',
    borderColor: 'var(--teal-dark)',
    benefits: [
      'Annual Report access',
      'Invitations to CMC events',
      'CMC gift of appreciation',
    ],
  },
  {
    name: 'CMC Champion',
    range: '$1,001 – $2,500',
    color: '#e0f0ed',
    borderColor: 'var(--teal-dark)',
    highlight: true,
    benefits: [
      'All CMC Friend benefits',
      'State of CMC virtual event invitation',
      'Recognition in donor communications',
    ],
  },
  {
    name: 'CMC Partner',
    range: '$2,501+',
    color: 'var(--navy-footer)',
    borderColor: 'var(--navy-footer)',
    dark: true,
    label: 'Major Gifts',
    benefits: [
      'All CMC Champion benefits',
      'Optional Annual Report acknowledgment',
      'Website recognition',
      'Exclusive donor recognition event',
    ],
  },
];

const programs = [
  { icon: '🎯', label: 'CMC The Rock', desc: 'Programs for teens & young adults' },
  { icon: '🏠', label: 'Care for Unhoused', desc: 'Families and individuals experiencing homelessness' },
  { icon: '🚐', label: 'CareLink Mobile', desc: 'Mobile health clinic services' },
  { icon: '🧓', label: 'Aging Adults', desc: 'Specialized care for older community members' },
  { icon: '👧', label: 'Children & Youth', desc: 'Pediatric and developmental care' },
  { icon: '❤️', label: 'Uninsured Families', desc: 'Care regardless of ability to pay' },
  { icon: '🏥', label: 'General Operating', desc: 'Sustain all CMC programs and services' },
];

const paymentOptions = [
  { label: 'Online', desc: 'One-time or installment payments online' },
  { label: 'Monthly Pledge', desc: 'Set up recurring monthly giving' },
  { label: 'By Check', desc: 'Mail a check to our administration office' },
  { label: 'Planned Giving', desc: 'Include CMC in your estate planning' },
];
---
<Base title="Support CMC" description="Support Community Medical Centers and help us provide quality healthcare to everyone in our community, regardless of ability to pay.">

  <div class="page-header">
    <div class="container">
      <div class="breadcrumb"><a href="/">Home</a> / Support CMC</div>
      <h1>The Gift of Health</h1>
      <p>Your generosity helps us provide quality care to everyone in our community — regardless of ability to pay.</p>
    </div>
  </div>

  <!-- Impact statement -->
  <section class="section-sm" style="background:var(--bg-alt);border-bottom:1px solid var(--border)">
    <div class="container" style="max-width:800px;text-align:center">
      <p style="font-size:1.1rem;line-height:1.8;color:var(--text)">
        Access to quality healthcare is slipping out of reach for so many in San Joaquin and Solano counties.
        When you give to CMC, you ensure that every patient — insured or not — receives the compassionate care they deserve.
      </p>
      <a href="https://cmcenters.org/support-cmc/" target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="margin-top:1.5rem">Donate Now</a>
    </div>
  </section>

  <!-- Donor Tier Program -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Your Impact</span>
        <h2>CMC Donor Tier Program</h2>
        <p style="color:var(--text-muted);max-width:580px;margin:0.75rem auto 0">Every level of giving makes a meaningful difference. Choose the tier that works for you.</p>
      </div>
      <div class="grid-3" style="margin-top:2.5rem">
        {tiers.map(tier => (
          <div style={`border-radius:12px;overflow:hidden;border:2px solid ${tier.borderColor};display:flex;flex-direction:column`}>
            <div style={`background:${tier.dark ? tier.color : tier.color};padding:1.5rem;text-align:center;border-bottom:2px solid ${tier.borderColor}`}>
              {tier.label && <div style={`font-size:0.7rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;margin-bottom:0.4rem;color:${tier.dark ? 'rgba(255,255,255,0.7)' : 'var(--teal-dark)'}`}>{tier.label}</div>}
              <div style={`font-size:1.25rem;font-weight:700;color:${tier.dark ? '#fff' : 'var(--teal-dark)'}`}>{tier.name}</div>
              <div style={`font-size:0.95rem;font-weight:500;margin-top:0.4rem;color:${tier.dark ? 'rgba(255,255,255,0.85)' : 'var(--text-muted)'}`}>{tier.range}</div>
            </div>
            <div style="padding:1.25rem 1.5rem;flex:1;background:#fff">
              <ul style="list-style:none;display:flex;flex-direction:column;gap:0.6rem">
                {tier.benefits.map(b => (
                  <li style="display:flex;align-items:flex-start;gap:0.6rem;font-size:0.88rem;color:var(--text)">
                    <span style="color:var(--teal-dark);flex-shrink:0;margin-top:0.1rem">✓</span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Beneficiary Programs -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Choose Your Impact</span>
        <h2>Beneficiary Program Areas</h2>
        <p style="color:var(--text-muted);max-width:580px;margin:0.75rem auto 0">Direct your gift to the programs and populations that matter most to you.</p>
      </div>
      <div class="grid-3" style="margin-top:2.5rem;gap:1.25rem">
        {programs.map(p => (
          <div style="background:var(--bg-alt);border:1px solid var(--border);border-radius:8px;padding:1.25rem 1.5rem;display:flex;gap:1rem;align-items:flex-start">
            <span style="font-size:1.5rem;flex-shrink:0">{p.icon}</span>
            <div>
              <div style="font-weight:600;font-size:0.9rem;color:var(--text)">{p.label}</div>
              <div style="font-size:0.82rem;color:var(--text-muted);margin-top:0.2rem">{p.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Payment Options + Planned Giving -->
  <section class="section">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start" class="support-split">

        <!-- Payment Options -->
        <div>
          <div class="section-header" style="text-align:left;margin-bottom:1.5rem">
            <span class="eyebrow">Flexibility</span>
            <h2>Payment Options</h2>
          </div>
          <div style="display:flex;flex-direction:column;gap:1rem">
            {paymentOptions.map(opt => (
              <div style="display:flex;gap:1rem;align-items:flex-start">
                <div style="width:8px;height:8px;border-radius:50%;background:var(--teal-dark);flex-shrink:0;margin-top:0.45rem"></div>
                <div>
                  <div style="font-weight:600;font-size:0.9rem">{opt.label}</div>
                  <div style="font-size:0.85rem;color:var(--text-muted)">{opt.desc}</div>
                </div>
              </div>
            ))}
          </div>
          <div style="margin-top:1.75rem">
            <a href="https://cmcenters.org/support-cmc/" target="_blank" rel="noopener noreferrer" class="btn btn-outline">Give Online</a>
          </div>
        </div>

        <!-- Major Gifts Contact -->
        <div>
          <div class="section-header" style="text-align:left;margin-bottom:1.5rem">
            <span class="eyebrow">Major Gifts &amp; Planned Giving</span>
            <h2>Partner With Us</h2>
          </div>
          <p style="color:var(--text-muted);font-size:0.9rem;line-height:1.7;margin-bottom:1.5rem">
            Interested in a major gift, legacy giving, or including CMC in your estate plan?
            Our Development Director would love to connect with you.
          </p>
          <div style="background:var(--bg-alt);border:1px solid var(--border);border-radius:8px;padding:1.5rem;display:flex;flex-direction:column;gap:0.75rem">
            <div style="font-weight:700;font-size:0.95rem">Jennie Rodriguez</div>
            <div style="font-size:0.82rem;color:var(--text-muted)">Development Director</div>
            <a href="tel:2093732454" style="font-size:0.88rem;font-weight:600;color:var(--teal-dark)">(209) 373-2454</a>
            <a href="mailto:jrmoore@cmcenters.org" style="font-size:0.88rem;color:var(--teal-dark)">jrmoore@cmcenters.org</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Signature Event -->
  <section class="section-sm" style="background:var(--navy-footer)">
    <div class="container" style="max-width:760px;text-align:center">
      <div class="eyebrow" style="display:inline-block;color:var(--teal);font-size:0.78rem;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:0.75rem">Signature Event</div>
      <h2 style="color:#fff;margin-bottom:0.75rem">Annual Gala: A Black &amp; White Masquerade</h2>
      <p style="color:rgba(255,255,255,0.75);font-size:0.95rem;line-height:1.7;margin-bottom:1.5rem">
        Join us each year for our signature fundraising gala. A celebration of community, compassion, and the future of healthcare in the Central Valley.
      </p>
      <a href="https://cmcenters.org/support-cmc/" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Learn About Sponsorships</a>
    </div>
  </section>

</Base>

<style>
  @media (max-width: 768px) {
    .support-split {
      grid-template-columns: 1fr !important;
      gap: 2.5rem !important;
    }
  }
</style>
