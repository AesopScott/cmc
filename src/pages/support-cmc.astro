---
import Base from '../layouts/Base.astro';

const tiers = [
  {
    name: 'CMC Friend',
    range: '$500 – $999',
    url: 'https://buy.stripe.com/cNibJ3c7wfxLcKH9Tn08g00?locale=en&__embed_source=buy_btn_1ST8xePMtXr6LYlQ00KUrcWs',
  },
  {
    name: 'CMC Champion',
    range: '$1,000 – $2,499',
    url: 'https://buy.stripe.com/14AcN70oO99n2639Tn08g01?locale=en&__embed_source=buy_btn_1ST9IWPMtXr6LYlQNsHTEMYq',
    highlight: true,
  },
  {
    name: 'CMC Partner',
    range: '$2,500+',
    url: 'https://buy.stripe.com/4gMcN77RggBP7qn3uZ08g02?locale=en&__embed_source=buy_btn_1ST9YkPMtXr6LYlQs4tefcgh',
    dark: true,
  },
];

const programs = [
  'CMC The Rock — Programs for teens & young adults',
  'Care for Unhoused — Families and individuals experiencing homelessness',
  'CareLink Mobile — Mobile health clinic services',
  'Aging Adults — Specialized care for older community members',
  'Children & Youth — Pediatric and developmental care',
  'Uninsured Families — Care regardless of ability to pay',
  'General Operating — Sustain all CMC programs and services',
];
---
<Base title="Support CMC" description="Support Community Medical Centers and help us provide quality healthcare to everyone in our community, regardless of ability to pay.">

  <!-- Your gift makes a difference -->
  <section class="section">
    <div class="container" style="max-width:860px">
      <h2 style="font-size:clamp(1.6rem,3vw,2.2rem);margin-bottom:1.75rem">Your gift makes a difference</h2>
      <p>Access to quality health care is slipping out of reach for so many in San Joaquin and Solano counties.</p>
      <p>As health insurance and other benefits are reduced, vulnerable families and hard-working people across our region are losing coverage and facing one of the most difficult moments in recent history. This is creating a ripple effect that puts thousands at risk. Now, more than ever, our community needs a lifeline.</p>
      <p>Community Medical Centers is firm in its mission to provide comprehensive, high-quality care to every person who walks through our doors, regardless of their ability to pay.</p>
      <p>Your gift will provide flexible, immediate support where it's needed most across our health programs. By giving once or giving monthly, you help ensure vulnerable patients continue to receive essential, life-changing care all year long. Together, we can sustain this safety net for health care and build a better future for all.</p>
      <p style="font-style:italic;color:var(--text-muted)">Donations are tax-deductible. Please consult with your tax accountant for information on tax deductions.</p>
    </div>
  </section>

  <hr class="divider" />

  <!-- How you can help -->
  <section class="section">
    <div class="container" style="max-width:860px">
      <h2 style="font-size:clamp(1.4rem,2.5vw,1.9rem);margin-bottom:1.75rem">How you can help</h2>
      <div class="help-buttons">
        <a href="https://cmcenters.org/support-cmc/#general-giving" target="_blank" rel="noopener noreferrer" class="btn btn-primary">No gift is too small</a>
        <a href="https://lp.constantcontactpages.com/cu/JIfUB8J/CMCahc" target="_blank" rel="noopener noreferrer" class="btn btn-primary">CMC The Rock Capital Campaign</a>
        <a href="#transformational-giving" class="btn btn-outline">Transformational Giving</a>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Donor Tier Program -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>CMC Donor Tier Program</h2>
      </div>
      <div class="grid-3" style="margin-top:2.5rem">
        {tiers.map(tier => (
          <div class={`tier-card${tier.dark ? ' tier-card--dark' : tier.highlight ? ' tier-card--highlight' : ''}`}>
            <div class="tier-header">
              <div class="tier-name">{tier.name}</div>
              <div class="tier-range">{tier.range}</div>
            </div>
            <div class="tier-body">
              <a href={tier.url} target="_blank" rel="noopener noreferrer" class={`btn ${tier.dark ? 'btn-primary' : 'btn-outline'}`} style="width:100%;text-align:center">Donate</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Beneficiary Programs + Giving by Check -->
  <section class="section">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start" class="support-split">

        <!-- Choose Beneficiary Program -->
        <div>
          <h2 style="font-size:1.3rem;margin-bottom:1.25rem">Choose Beneficiary Program</h2>
          <ul class="program-list">
            {programs.map(p => <li>{p}</li>)}
          </ul>
        </div>

        <!-- Giving by Check -->
        <div>
          <h2 style="font-size:1.3rem;margin-bottom:1.25rem">Giving by Check</h2>
          <p style="color:var(--text-muted);font-size:0.95rem;line-height:1.7;margin-bottom:1rem">Checks can be made payable to <strong>Community Medical Centers</strong> and mailed to:</p>
          <address style="font-style:normal;background:var(--bg-alt);border:1px solid var(--border);border-radius:8px;padding:1.25rem 1.5rem;font-size:0.92rem;line-height:1.8;color:var(--text)">
            Community Medical Centers<br />
            Attn: Development Department<br />
            7210 Murray Drive<br />
            Stockton, CA 95210
          </address>
          <p style="color:var(--text-muted);font-size:0.875rem;line-height:1.6;margin-top:1rem">Please include any designation or instructions with your gift so we can ensure it supports the area most meaningful to you.</p>
        </div>

      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Transformational Giving -->
  <section class="section" id="transformational-giving">
    <div class="container" style="max-width:860px">
      <h2 style="font-size:clamp(1.4rem,2.5vw,1.9rem);margin-bottom:1.5rem">Transformational Giving</h2>
      <p>Transformational gifts help Community Medical Centers expand access to care, strengthen services, and invest in the future health of our communities. Major gifts and planned gifts—such as bequests, beneficiary designations, and other legacy gifts—can make a lasting difference for patients and families across the communities we serve.</p>
      <p>To learn more about making a major or planned gift, contact Director of Development Jennie Rodriguez at <a href="mailto:jrmoore@cmcenters.org" style="color:var(--teal-dark)">jrmoore@cmcenters.org</a> or <a href="tel:2093732454" style="color:var(--teal-dark)">(209) 373-2454</a>.</p>
    </div>
  </section>

</Base>

<style>
  p { color: var(--text-muted); line-height: 1.8; margin-bottom: 1.1rem; }
  .help-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .tier-card {
    border: 2px solid var(--teal-dark);
    border-radius: 12px;
    overflow: hidden;
  }
  .tier-card--highlight {
    border-color: var(--teal-dark);
    box-shadow: 0 4px 20px rgba(38,122,112,0.18);
  }
  .tier-card--dark {
    border-color: var(--navy-footer);
  }
  .tier-header {
    background: var(--teal-light);
    padding: 1.5rem;
    text-align: center;
    border-bottom: 2px solid var(--teal-dark);
  }
  .tier-card--dark .tier-header {
    background: var(--navy-footer);
    border-bottom-color: var(--navy-footer);
  }
  .tier-name {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--teal-dark);
  }
  .tier-card--dark .tier-name { color: #fff; }
  .tier-range {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-top: 0.3rem;
  }
  .tier-card--dark .tier-range { color: rgba(255,255,255,0.8); }
  .tier-body {
    padding: 1.25rem 1.5rem;
    background: #fff;
  }
  .program-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .program-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.92rem;
    color: var(--text-muted);
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .program-list li::before {
    content: '·';
    color: var(--teal-dark);
    font-weight: 700;
    flex-shrink: 0;
  }
  @media (max-width: 768px) {
    .support-split { grid-template-columns: 1fr !important; gap: 2.5rem !important; }
  }
</style>
